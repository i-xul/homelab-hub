# ---------------------------------------------------------
# Flask
# ---------------------------------------------------------

FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret-key

HOMELAB_HUB_HOST=127.0.0.1
HOMELAB_HUB_PORT=5000


# ---------------------------------------------------------
# Network discovery
# ---------------------------------------------------------

HOMELAB_HUB_NETWORK=192.168.1.0/24
HOMELAB_HUB_SCAN_INTERVAL=300
HOMELAB_HUB_OFFLINE_THRESHOLD=3
HOMELAB_HUB_NMAP_TIMEOUT=120